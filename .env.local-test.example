# Local Testing Environment Variables
# Used for testing production deployment locally
#
# Example file — copy to .env.local-test (gitignored) and adjust values.
# The SECRET_KEY below is a placeholder; replace it locally if you want
# session secrets to differ from this committed example.

# Database
DB_PASSWORD=test_password_123

# Application
SECRET_KEY=local_test_secret_key_for_development_only_change_in_production
LOG_LEVEL=DEBUG
DEBUG=true

# Domain (for local testing)
DOMAIN=localhost
